### [src/utils/date.js](file:///d:/BB/news/src/utils/date.js) — Date Formatter
```js
export function formatDate(iso) {
  // iso = ISO 8601 string like '2024-01-15T10:30:00.000Z'
  
  if (!iso) return ''
  
  const date = new Date(iso)
  // new Date() parses the ISO string into a JavaScript Date object
  
  if (Number.isNaN(date.getTime())) return iso
  // If parsing failed, getTime() returns NaN. Return raw string as fallback.
  
  return date.toLocaleDateString('en-US', {
    day: 'numeric',    // 5
    month: 'short',    // Jan
    year: 'numeric'    // 2024
  })
  // Output: "Jan 5, 2024"
}
```

